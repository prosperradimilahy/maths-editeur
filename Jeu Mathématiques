

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Katro</title>
    <style>


:root {
  --ink:     #0D0D0D;
  --paper:   #F5F0E8;
  --cream:   #EDE6D3;
  --gold:    #C8962E;
  --gold2:   #E8B84B;

}

        body {
            font-family: Arial, sans-serif;
            background-color: #f0f0f0;
        }
       .conteneur {
            width: 80%;
            margin: 0 auto;
            text-align: center;
        }
        #plateau {
            display: flex;
            justify-content: space-around;
            margin-top: 20px;
        }
       .trou {
            width: 50px;
            height: 50px;
            border: 1px solid #ccc;

            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 24px;
            cursor: pointer;
            background-color: #8B4513;
            color: #fff;
        }
       .trou:hover {
            background-color: #A52A2A;
        }
        #historique {
            margin-top: 20px;
            padding: 10px;
            border: 1px solid #ccc;
            width: 50%;
            height: 200px;
            overflow-y: auto;
            margin: 0 auto;
            background-color: #F5F5DC;
        }
     /*   button {
            margin: 10px;
            padding: 10px 20px;
            border: none;
            border-radius: 5px;
            background-color: #4CAF50;
            color: #fff;
            cursor: pointer;
        }*/
        button:hover {
            background-color: #3e8e41;
        }

.logo-text {
  font-style: italic;
  font-size: 1.35rem; font-weight: 700;
  letter-spacing: -.01em;
  color: var(--blanc);
}
.logo-text span { color: var(--gold); }

button {
    margin: 10px;
    padding: 10px 20px;
    border: 1px solid #D4A843;        /*>
    border-radius: 5px;
    background-color: #D4A843;        /*>
    color: #0A0A0A;                   /*>
    cursor: pointer;
    font-weight: 600;
    transition: all 0.25s ease;
}

    </style>
</head>
<body>
    <div class="conteneur">
        <h1 class="logo-text">Des<span>Chiffres</span></h1>
        <div id="plateau"></div>
        <div id="historique"></div>
        <button id="reinitialiser">Réinitialiser</button>
        <button id="copierHistorique">Copier et poster la solution</button>
<h1 class="logo-text">Le jeu Mathematique de Math<span>Connect</span></h1>
    </div>
    <script>
        // Initialisation du plateau
        let plateau = [1, 2, 0, 3, 5, 0, 2, 4];
        let solution = [];
        let nouveauTour = true;

        // Fonction pour afficher le plateau
        function afficherPlateau() {
            let html = '';
            for (let i = 0; i < plateau.length; i++) {
                html += `<div class="trou" onclick="jouer(${i})">${plateau[i]}</div>`;
            }
            document.getElementById('plateau').innerHTML = html;
            nouveauTour = true;
        }

        // Fonction pour jouer un coup
        function jouer(index) {
            if (nouveauTour) {
                solution.push(index);
                if (solution.length > 100) {
                    solution.shift();
                }
                afficherHistorique();
                nouveauTour = false;
            }
            let graines = plateau[index];
            plateau[index] = 0;
            let i = (index + 1) % plateau.length;
            while (graines > 0) {
                plateau[i]++;
                graines--;
                i = (i + 1) % plateau.length;
            }
            // Vérifier si le dernier grain tombe dans un trou vide
            if (plateau[(i - 1 + plateau.length) % plateau.length] === 1) {
                // Fin du tour
                afficherPlateau();
            } else {
                // Continuer le tour
                jouer((i - 1 + plateau.length) % plateau.length);
            }
        }

        // Fonction pour afficher l'historique
        function afficherHistorique() {
            let html = 'Historique : ';
            for (let i = 0; i < solution.length; i++) {
                html += solution[i] + ' ';
            }
            document.getElementById('historique').innerHTML = html;
            document.getElementById('historique').scrollTop = document.getElementById('historique').scrollHeight;
        }

        // Fonction pour copier l'historique
        function copierHistorique() {
            navigator.clipboard.writeText(solution.join(', '));
            alert('Historique copié dans le presse-papiers!');
        }

        // Fonction pour réinitialiser le jeu
        function reinitialiser() {
            plateau = [1, 2, 0, 0, 5, 0, 0, 4];
            solution = [];
            nouveauTour = true;
            afficherPlateau();
            document.getElementById('historique').innerHTML = '';
        }

        // Afficher le plateau initial
        afficherPlateau();

        // Ajouter des écouteurs d'événements aux boutons
        document.getElementById('reinitialiser').addEventListener('click', reinitialiser);
        document.getElementById('copierHistorique').addEventListener('click', copierHistorique);
    </script>
</body>
</html>
